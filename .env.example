# MongoDB
MONGODB_URI='mongodb://localhost:27017/groktool?replicaSet=rs0&directConnection=true'

# OpenAI API Key
# Right now, this is only used specifically for the syncTranslation.ts script
OPENAI_API_KEY=sk-...yourkey...
# This is still for OpenAI API Key, used in analytics generation script. We should only use one of this environment variable
API_KEY=sk-...yourkey...

# Is Preview Environment, true will skip tier 1 secrets validation
IS_PREVIEW=true

# Brand identity (open-core, issue #9310) — no brand fallback. When unset, the app ships no
# product name / marketing links and inbound-email ingestion accepts nothing. Set these to
# your own brand; APP_NAME/WEBSITE_URL are also inlined into the client bundle at build time.
# APP_NAME='Your Product'
# WEBSITE_URL='https://www.your-domain.com'
# PLATFORM_EMAIL_DOMAIN='@app.your-domain.com'

# Account-tied deployment domain (issue #9306) — derives app/staging/preview hosts, CSP/SSRF
# allowlists, and the platform email host. No brand fallback.
# SERVER_DOMAIN='your-domain.com'
# LOGO_URL='https://cdn.your-domain.com/logo.png'

# What's New Distribution (SST Infrastructure)
# Set to 'true' ONLY on the main production environment that generates and publishes What's New modals.
# This creates the S3 bucket and CloudFront distribution for sharing modals with fork environments.
# Fork environments should NOT set this - they consume modals via WHATS_NEW_DISTRIBUTION_URL instead.
# ENABLE_WHATS_NEW_DISTRIBUTION=true
