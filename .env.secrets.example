# Example secrets file - copy to .env.secrets and fill in actual values
# This file shows the environment variables needed for development

# GitHub Fine-Grained Personal Access Token for MCP integration
# Required permissions: repo, read:org, read:user
# Generate at: https://github.com/settings/personal-access-tokens/new (use Fine-grained tokens, NOT Classic tokens)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_personal_access_token_here

# Atlassian OAuth Credentials for Confluence/Jira MCP integration
# Required for token refresh functionality
# Create OAuth 2.0 app at: https://developer.atlassian.com/console/myapps/
# Scopes needed: read:confluence-content.all, write:confluence-content, read:jira-work, write:jira-work, offline_access
ATLASSIAN_CLIENT_ID=your_atlassian_oauth_client_id_here
ATLASSIAN_CLIENT_SECRET=your_atlassian_oauth_client_secret_here

# Add other sensitive environment variables below as needed