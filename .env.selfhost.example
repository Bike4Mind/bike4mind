# ── Bike4Mind self-host configuration ─────────────────────────────────
# Auto-derived from the @bike4mind/resource manifest (open-core #9313). Regenerate from the manifest;
# do not hand-edit the key list. REQUIRED vars fail loud when their feature runs; OPTIONAL may stay unset.

B4M_SELF_HOST=true
APP_NAME=bike4mind
APP_STAGE=selfhost

# ── Core (required to boot) ──
MONGODB_URI=mongodb://mongo:27017/bike4mind?replicaSet=rs0
JWT_SECRET=change-me-openssl-rand-hex-32
SESSION_SECRET=change-me-openssl-rand-hex-32
SECRET_ENCRYPTION_KEY=change-me-openssl-rand-hex-32

# ── Realtime (required): local websocket gateway (see #9313 M4) ──
WEBSOCKET_MANAGEMENT_ENDPOINT=http://ws:3001
WEBSOCKET_URL=ws://localhost:3001

# ── Object storage → MinIO (bucket names) ──
APP_FILES_BUCKET=b4m-app-files
EMAIL_INGESTION_BUCKET=b4m-email-ingestion
FAB_FILE_BUCKET=b4m-fab-file
GENERATED_IMAGES_BUCKET=b4m-generated-images
HISTORY_IMPORT_BUCKET=b4m-history-import
PUBLISHED_ARTIFACTS_BUCKET=b4m-published-artifacts
SLACK_EXPORT_BUCKET=b4m-slack-export

# ── Queues → ElasticMQ / LocalStack SQS (full queue URLs) ──
AGENT_CONTINUATION_QUEUE=http://sqs:9324/000000000000/agentContinuationQueue
AGENT_PROACTIVE_MESSAGE_QUEUE=http://sqs:9324/000000000000/agentProactiveMessageQueue
DEEP_AGENT_WAKE_QUEUE=http://sqs:9324/000000000000/deepAgentWakeQueue
EMAIL_ANALYSIS_QUEUE=http://sqs:9324/000000000000/emailAnalysisQueue   # OPTIONAL
EMAIL_BATCH_QUEUE=http://sqs:9324/000000000000/emailBatchQueue
EMAIL_INGESTION_QUEUE=http://sqs:9324/000000000000/emailIngestionQueue
EMAIL_JOB_QUEUE=http://sqs:9324/000000000000/emailJobQueue
FAB_FILE_CHUNK_QUEUE=http://sqs:9324/000000000000/fabFileChunkQueue
FAB_FILE_VECTORIZE_QUEUE=http://sqs:9324/000000000000/fabFileVectorizeQueue
LIVE_OPS_TRIAGE_QUEUE=http://sqs:9324/000000000000/liveOpsTriageQueue
NOTEBOOK_CURATION_QUEUE=http://sqs:9324/000000000000/notebookCurationQueue   # OPTIONAL
RESEARCH_ENGINE_QUEUE=http://sqs:9324/000000000000/researchEngineQueue
SRE_ANALYSIS_QUEUE=http://sqs:9324/000000000000/sreAnalysisQueue
SRE_FIX_QUEUE=http://sqs:9324/000000000000/sreFixQueue
TAVERN_HEARTBEAT_QUEUE=http://sqs:9324/000000000000/tavernHeartbeatQueue

# ── Lambda functions / event buses (names; local services per #9313 M4) ──
AGENT_EXECUTOR=agent-executor
APP_EVENT_BUS=app-event-bus
HISTORY_UPLOAD_COMPLETE_FUNCTION=history-upload-complete-function
IMAGE_PROCESSOR=image-processor
NOTEBOOK_IMPORT_COMPLETE_FUNCTION=notebook-import-complete-function
SLACK_EVENT_BUS=slack-event-bus
MCP_HANDLER=mcp-handler   # OPTIONAL

# ── Secrets & integrations (leave blank to disable that integration) ──
ANTHROPIC_API_KEY=   # required if you use this integration
B4M_ANALYTICS_ENABLED=   # OPTIONAL
B4M_PROD_API_KEY=   # OPTIONAL
E2E_CLEANUP_SECRET=   # OPTIONAL
EMERGENCY_LOGIN_ENABLED=   # OPTIONAL
GEMINI_API_KEY=   # required if you use this integration
GITHUB_CLIENT_ID=   # required if you use this integration
GITHUB_CLIENT_SECRET=   # required if you use this integration
GITHUB_ZAP_REF=   # OPTIONAL
GOOGLE_CLIENT_ID=   # required if you use this integration
GOOGLE_CLIENT_SECRET=   # required if you use this integration
MAIL_FROM=   # required if you use this integration
MAIL_HOST=   # required if you use this integration
MAIL_PASSWORD=   # required if you use this integration
MAIL_PORT=   # required if you use this integration
MAIL_USERNAME=   # required if you use this integration
OAUTH_RSA_PRIVATE_KEY=   # OPTIONAL
OKTA_AUDIENCE=   # required if you use this integration
OKTA_CLIENT_ID=   # required if you use this integration
OKTA_CLIENT_SECRET=   # required if you use this integration
OKTA_USE_ORG_AUTH_SERVER=   # OPTIONAL
OVERWATCH_INGEST_ENABLED=   # OPTIONAL, transient (removed after product extraction)
OVERWATCH_INGEST_KEY=   # OPTIONAL, transient (removed after product extraction)
OVERWATCH_INGEST_URL=   # OPTIONAL, transient (removed after product extraction)
OVERWATCH_PSEUDONYM_SALT=   # OPTIONAL, transient (removed after product extraction)
OPTIHASHI_API_TOKEN=   # OPTIONAL
OPTIHASHI_API_URL=   # OPTIONAL
OPTIHASHI_WEBHOOK_SECRET=   # OPTIONAL
OPTIHASHI_WEBHOOK_SECRET_PREVIOUS=   # OPTIONAL
RATE_LIMIT_INGEST_TOKEN=   # OPTIONAL
SECOPS_ATTACK_SIMULATION_INGEST_TOKEN=   # OPTIONAL
SECOPS_CODE_INGEST_TOKEN=   # OPTIONAL
SECOPS_PACKAGES_INGEST_TOKEN=   # OPTIONAL
SECOPS_PROWLER_INGEST_TOKEN=   # OPTIONAL
SECOPS_PROWLER_WORKFLOW_TOKEN=   # OPTIONAL
SECOPS_SECRETS_INGEST_TOKEN=   # OPTIONAL
SECOPS_ZAP_DISPATCH_TOKEN=   # OPTIONAL
SECOPS_ZAP_INGEST_TOKEN=   # OPTIONAL
SECRET_ENCRYPTION_KEY_PREVIOUS=   # OPTIONAL
SLACK_ERROR_REPORTING_WEBHOOK_URL=   # required if you use this integration
SLACK_WEBHOOK_URL=   # required if you use this integration
STRIPE_PUBLISHABLE_KEY=   # required if you use this integration
STRIPE_SECRET_KEY=   # required if you use this integration
STRIPE_WEBHOOK_SECRET=   # required if you use this integration
SUPPORT_EMAIL=   # required if you use this integration
WHATS_NEW_DISTRIBUTION_URL=   # OPTIONAL

# ── JSON map, optional ──
LAMBDA_FUNCTION_NAMES=   # OPTIONAL, e.g. {"attackSimulation":"fn-name"}
