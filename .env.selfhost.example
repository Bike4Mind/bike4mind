OVERWATCH_INGEST_ENABLED=
OVERWATCH_INGEST_KEY=
OVERWATCH_INGEST_URL=
OVERWATCH_PSEUDONYM_SALT=

# -- OptiHashi external-compute integration (optional) --
OPTIHASHI_API_TOKEN=
OPTIHASHI_API_URL=
OPTIHASHI_WEBHOOK_SECRET=
OPTIHASHI_WEBHOOK_SECRET_PREVIOUS=

# -- JSON map, optional --
# Example: {"attackSimulation":"fn-name"}
LAMBDA_FUNCTION_NAMES=

# -- Public internet exposure (share with friends) -----------------------------
# The stack defaults to local/single-host use. To reach it from other machines,
# see "Share your instance with friends (secure internet exposure)" in SELF_HOST.md.
# Two paths: a Tailscale tailnet (recommended for a few friends, nothing public), or
# the bundled Caddy reverse proxy with automatic HTTPS on a public domain. For Caddy,
# set B4M_DOMAIN and change WEBSOCKET_URL to wss://<domain>/ws, then bring the stack up
# with `-f compose.caddy.yaml --profile proxy` (full checklist + env deltas in SELF_HOST.md).
# B4M_DOMAIN=chat.example.com
#
# Tailscale path: enable MagicDNS + HTTPS certs in your tailnet, set an auth key below,
# and bring the stack up with `-f compose.tailscale.yaml --profile tailnet`. After it joins,
# set WEBSOCKET_URL=wss://<your-node>.tailXXXX.ts.net/ws and re-up.
# TS_AUTHKEY=tskey-auth-...
# TS_HOSTNAME=bike4mind
