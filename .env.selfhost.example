# -- Bike4Mind self-host configuration ---------------------------------
# Derived from the @bike4mind/resource config manifest; keep the key list in
# sync with it. Required vars fail loud when their feature runs; optional
# vars may stay unset.
#
# IMPORTANT: docker compose env_file values are taken verbatim - never put a
# comment on the same line as a value (it would become part of the value).

B4M_SELF_HOST=true
APP_NAME=bike4mind
APP_STAGE=selfhost

# -- Core (required to boot) --
# Generate each secret with: openssl rand -hex 32
# Never change SECRET_ENCRYPTION_KEY after first boot - it encrypts secrets
# stored in the database and cannot be rotated in place.
MONGODB_URI=mongodb://mongo:27017/bike4mind?replicaSet=rs0
JWT_SECRET=change-me-openssl-rand-hex-32
SESSION_SECRET=change-me-openssl-rand-hex-32
SECRET_ENCRYPTION_KEY=change-me-openssl-rand-hex-32

# -- Realtime websocket gateway --
# Provided by the `ws` + `subscriber-fanout` services in compose.selfhost.yaml.
# The app + fanout push to WEBSOCKET_MANAGEMENT_ENDPOINT (compose network); the
# browser connects to WEBSOCKET_URL (host-published). If you remap the host port,
# set WS_HOST_PORT and update WEBSOCKET_URL to match.
WEBSOCKET_MANAGEMENT_ENDPOINT=http://ws:3001
WEBSOCKET_URL=ws://localhost:3001
# Shared secret the ws gateway uses to authenticate its internal handler calls
# to the app. Generate with: openssl rand -hex 32
INTERNAL_WS_SECRET=change-me-openssl-rand-hex-32
# Shared secret MinIO sends (Authorization header) to the app's S3 ObjectCreated
# webhook (/api/internal/s3/object-created), which triggers RAG ingestion on upload.
# Generate with: openssl rand -hex 32
INTERNAL_S3_WEBHOOK_SECRET=change-me-openssl-rand-hex-32
# Override to pin/point the fanout image (defaults to the published GHCR tag):
# SUBSCRIBER_FANOUT_IMAGE=ghcr.io/bike4mind/subscriber-fanout:latest

# -- Always-on chatCompletion service --
# The `chatcompletion` service in compose.selfhost.yaml (the self-host equivalent of the
# hosted Fargate ChatCompletion). The `app` container dispatches created quests to
# ${CHAT_COMPLETION}/process and it streams replies back through the ws gateway.
# Reached over the compose network by service name; keep the internal port 8080.
CHAT_COMPLETION=http://chatcompletion:8080
# Shared secret the `app` presents when dispatching quests to ${CHAT_COMPLETION}/process,
# and that the `chatcompletion` service checks. Both containers read it from this env_file,
# so the value must match on both. Generate with: openssl rand -hex 32
CHAT_COMPLETION_INTERNAL_SECRET=change-me-openssl-rand-hex-32
# Public origin where clients OUTSIDE the compose network (the CLI, 3rd-party API callers)
# reach the chatcompletion service's /api/ai/v1/completions SSE endpoint. Advertised to the
# CLI via /api/settings/serverConfig; without it the CLI falls back to the app origin, which
# does not route that path on self-host. Keep the port in sync with CHATCOMPLETION_HOST_PORT
# (compose.selfhost.yaml, default 8788); use your public hostname if serving beyond localhost.
CHAT_COMPLETION_PUBLIC_URL=http://localhost:8788

# -- Local infra backends (Docker Compose) - dev defaults, CHANGE for production --
# MinIO admin creds (conventional local default; used by the app's S3 client too).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# -- Published host ports (override only if a port is already taken on your host) --
# These change the HOST side of the port publish only; services still talk to
# each other over the compose network on their fixed internal ports. Example: a
# local mongod already on 27017 -> set MONGO_HOST_PORT=27018. Leave unset to keep
# the defaults shown.
# APP_HOST_PORT=3000
# MONGO_HOST_PORT=27017
# MINIO_HOST_PORT=9000
# MINIO_CONSOLE_HOST_PORT=9001
# SQS_HOST_PORT=9324
# SQS_UI_HOST_PORT=9325
# MAIL_UI_HOST_PORT=8025
# CHATCOMPLETION_HOST_PORT=8788   # host port for the chatcompletion service :8080 (also serves /api/ai/v1/completions)
# SEARXNG_HOST_PORT=8080          # host port for the optional searxng service (see Local web search below)
# Point the app's AWS SDK (S3 + SQS) at the local MinIO/ElasticMQ services.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL_S3=http://minio:9000
AWS_ENDPOINT_URL_SQS=http://sqs:9324

# -- Mail (sign-in codes are delivered by email) --
# Defaults point at the bundled Mailpit catcher: read mail at
# http://localhost:8025. Point these at a real SMTP provider for production
# and use port 465 (implicit TLS) or 587 (mandatory STARTTLS).
MAIL_HOST=mail
MAIL_PORT=1025
MAIL_USERNAME=selfhost
MAIL_PASSWORD=selfhost
MAIL_FROM=bike4mind@selfhost.local

# -- Object storage -> MinIO (bucket names) --
APP_FILES_BUCKET=b4m-app-files
EMAIL_INGESTION_BUCKET=b4m-email-ingestion
FAB_FILE_BUCKET=b4m-fab-file
GENERATED_IMAGES_BUCKET=b4m-generated-images
HISTORY_IMPORT_BUCKET=b4m-history-import
# Published artifact bundles (Share > Publish) upload THROUGH the app, which
# writes the bytes into this bucket - so MinIO never needs to be reachable from
# the browser (unlike the hosted presigned-URL path). Behind a TLS reverse proxy,
# forward the Host header and set X-Forwarded-Proto=https so the published
# viewer's Content-Security-Policy resolves the right origin and scheme.
# Abandoned publish drafts under this bucket's drafts/ prefix are auto-expired
# after 7 days by a MinIO lifecycle rule (set by the createbuckets service); a
# finalized publish deletes its own draft.
PUBLISHED_ARTIFACTS_BUCKET=b4m-published-artifacts
SLACK_EXPORT_BUCKET=b4m-slack-export

# -- Asset delivery (browser-facing URL for S3-backed files) --
# Self-host has no CloudFront CDN, so the app serves generated images, profile
# photos, org logos, and cached external images through its own proxy route
# (/api/app-files/serve) backed by MinIO. This is the self-host analog of the CDN
# URL that hosted stages set; infra sets it to this same path for personal dev
# stages. The client reads it at runtime from /api/settings/serverConfig, and the
# proxy route serves only while NEXT_PUBLIC_CDN_URL equals this path. Leave as-is
# unless you front the app with your own CDN/reverse proxy for these buckets.
NEXT_PUBLIC_CDN_URL=/api/app-files/serve

# -- Queues -> ElasticMQ (full queue URLs, predeclared in elasticmq.conf) --
AGENT_CONTINUATION_QUEUE=http://sqs:9324/000000000000/agentContinuationQueue
AGENT_PROACTIVE_MESSAGE_QUEUE=http://sqs:9324/000000000000/agentProactiveMessageQueue
DEEP_AGENT_WAKE_QUEUE=http://sqs:9324/000000000000/deepAgentWakeQueue
EMAIL_ANALYSIS_QUEUE=http://sqs:9324/000000000000/emailAnalysisQueue
EMAIL_BATCH_QUEUE=http://sqs:9324/000000000000/emailBatchQueue
EMAIL_INGESTION_QUEUE=http://sqs:9324/000000000000/emailIngestionQueue
EMAIL_JOB_QUEUE=http://sqs:9324/000000000000/emailJobQueue
FAB_FILE_CHUNK_QUEUE=http://sqs:9324/000000000000/fabFileChunkQueue
FAB_FILE_VECTORIZE_QUEUE=http://sqs:9324/000000000000/fabFileVectorizeQueue
LIVE_OPS_TRIAGE_QUEUE=http://sqs:9324/000000000000/liveOpsTriageQueue
NOTEBOOK_CURATION_QUEUE=http://sqs:9324/000000000000/notebookCurationQueue
RESEARCH_ENGINE_QUEUE=http://sqs:9324/000000000000/researchEngineQueue
# Background enrichment events (naming, summaries, tags, memento embedding). The app
# publishes here; the `worker` service consumes them (see server/worker/eventDispatch.ts).
SELF_HOST_EVENT_QUEUE=http://sqs:9324/000000000000/selfHostEventQueue
SRE_ANALYSIS_QUEUE=http://sqs:9324/000000000000/sreAnalysisQueue
SRE_FIX_QUEUE=http://sqs:9324/000000000000/sreFixQueue
TAVERN_HEARTBEAT_QUEUE=http://sqs:9324/000000000000/tavernHeartbeatQueue

# -- Lambda functions / event buses (names; not backed by local services yet) --
AGENT_EXECUTOR=agent-executor
APP_EVENT_BUS=app-event-bus
HISTORY_UPLOAD_COMPLETE_FUNCTION=history-upload-complete-function
IMAGE_PROCESSOR=image-processor
NOTEBOOK_IMPORT_COMPLETE_FUNCTION=notebook-import-complete-function
SLACK_EVENT_BUS=slack-event-bus
MCP_HANDLER=mcp-handler

# -- LLM provider keys --
# Set the providers you use; a blank key disables that provider. Keys can
# also be added per-user later in the app (Settings > API Keys), which
# overrides these.
#
# You do NOT need any of these if you run local models via Ollama (below).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# -- Local models via Ollama (no provider keys, runs offline once pulled) ------
# The fastest way to get chat working with zero API keys. When OLLAMA_BASE_URL
# is set, every model on that Ollama server shows up in the app's model picker
# automatically, with no admin settings to flip.
#
# Quick start (uses the bundled `ollama` compose service, CPU by default):
#   1. Uncomment OLLAMA_BASE_URL below.
#   2. Choose your model(s) in OLLAMA_PULL_MODELS (menu + specs below).
#   3. Bring the stack up with the `ollama` profile:
#        docker compose -f compose.selfhost.yaml --env-file .env.selfhost --profile ollama up -d
#      (add `-f compose.ollama-gpu.yaml` before --env-file for NVIDIA GPU.)
#
# Prefer an Ollama you already run on the host (e.g. native GPU)? Point at it
# instead (no `ollama` profile needed):
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# OLLAMA_BASE_URL=http://ollama:11434

# Model(s) the bundled puller downloads (space-separated). Qwen menu; pick by
# the hardware you have. "GPU VRAM" = fits fully on that GPU; with less VRAM it
# still runs, spilling to CPU RAM (slower). "CPU-only RAM" = usable with no GPU.
# Qwen2.5-Coder is tuned for coding (Bike4Mind's main use); qwen3 is newer/general.
#
#   Model tag              Download  Min GPU VRAM   CPU-only RAM   Notes
#   ---------------------  --------  ------------   ------------   ----------------------------
#   qwen2.5-coder:1.5b     ~1.0 GB   ~2 GB          ~8 GB          Tiny; fast even on CPU
#   qwen2.5-coder:3b       ~2.0 GB   ~4 GB          ~8 GB          Good on small/laptop GPUs
#   qwen2.5-coder:7b       ~4.7 GB   ~6-8 GB        ~16 GB         Recommended default
#   qwen2.5-coder:14b      ~9 GB     ~12 GB         ~32 GB         Stronger; needs a real GPU
#   qwen2.5-coder:32b      ~20 GB    ~24 GB         ~64 GB         Best local coder
#   qwen3:8b               ~5 GB     ~8 GB          ~16 GB         General-purpose alternative
#
# No GPU? Everything above runs on CPU, just start small (1.5b/3b). You can
# list several here to offer a choice in the picker, e.g.
#   OLLAMA_PULL_MODELS=qwen2.5-coder:3b qwen2.5-coder:7b
#
# EMBEDDINGS (offline RAG): the default below also pulls qwen3-embedding:0.6b so file
# search / knowledge base works fully offline with no cloud key. In self-host with no
# cloud embedding key, that model is the default automatically; to switch, set the admin
# "Default Embedding Model" (Settings -> AI) to another pulled embedder. Add its tag to the
# pull list first. Pick a size by the hardware you have, remembering a self-host box may run a
# chat model, an image model, and the embedder on the SAME GPU:
#
#   Embedder tag             Download  Dims   Min GPU VRAM  Notes
#   -----------------------  --------  -----  ------------  --------------------------------------
#   qwen3-embedding:0.6b     ~1.2 GB   1024   ~2 GB         Default; strong quality, fits any GPU/CPU
#   qwen3-embedding:4b       ~4.7 GB   2560   ~6-8 GB       Higher quality; needs a real GPU
#   qwen3-embedding:8b       ~9 GB     4096   ~12 GB        Best quality; big GPU only
#   nomic-embed-text         ~0.3 GB   768    ~1 GB         Cheapest/smallest option
#   mxbai-embed-large        ~0.7 GB   1024   ~2 GB         Short context (512)
#   bge-m3                   ~1.2 GB   1024   ~2 GB         Long context (8192); multilingual
#   snowflake-arctic-embed   ~0.7 GB   1024   ~2 GB         Retrieval-tuned; short context
#
# The embedder is unloaded after each call by default (OLLAMA_EMBED_KEEP_ALIVE=0) so it does not
# pin VRAM next to a chat model on a small (e.g. 4 GB) card; raise it if you embed constantly.
# NOTE: changing the embedding model changes vector dimensions; existing files stay on their old
# model until re-processed (/api/files/reprocess). Mixed-dimension vectors are simply skipped in
# search (see computeCosineSimilarity), not errors.
OLLAMA_PULL_MODELS=qwen2.5-coder:7b qwen3-embedding:0.6b

# -- Local web search via SearXNG (no SerpAPI key) -----------------------------
# Runs a self-hosted metasearch engine so the web_search tool (and deep_research)
# work with no external search key. Uses the bundled `searxng` compose service.
#
# Quick start:
#   1. Uncomment SEARXNG_BASE_URL below.
#   2. Bring the stack up with the `search` profile:
#        docker compose -f compose.selfhost.yaml --env-file .env.selfhost --profile search up -d
#
# When set, web_search prefers SearXNG automatically (WebSearchProvider=auto). Set
# a SerperKey in Admin > API Keys to use SerpAPI instead, or force a provider with
# the WebSearchProvider admin setting.
#
# SEARXNG_BASE_URL=http://searxng:8080
#
# secret_key for the SearXNG instance (used for its image-proxy HMAC; the JSON
# search API works regardless). Change from the local-dev default for real use.
SEARXNG_SECRET=selfhost-local-dev

# -- Web page fetching / scraping (Firecrawl, optional) ------------------------
# The web_fetch tool and deep_research use Firecrawl to render and extract page
# content. Without ANY Firecrawl config, web_fetch falls back to a keyless direct
# fetch + HTML->markdown reader. That fallback cannot run JavaScript-heavy pages
# or parse PDFs (upload PDFs directly instead) - configure Firecrawl for those.
#
# Point at a self-hosted Firecrawl instance (no key needed), and/or set a key for
# the hosted Firecrawl cloud. Either can also be set per-instance in Admin > API Keys.
# FIRECRAWL_API_URL=http://firecrawl:3002
FIRECRAWL_API_KEY=

# -- Local image generation (no provider keys, self-hosted Stable Diffusion) ---
# Generate images on your own hardware with NO provider API keys, via a bundled
# SD.Next server that exposes the AUTOMATIC1111-compatible REST API. When
# IMAGE_GEN_BASE_URL is set, its installed checkpoints show up in the app's image
# model picker automatically (as `local-image/<checkpoint>`), with no admin
# settings to flip. Mirrors OLLAMA_BASE_URL, but for images.
#
# Quick start (uses the bundled `imagegen` compose service, CPU by default):
#   1. Uncomment IMAGE_GEN_BASE_URL below.
#   2. Choose your checkpoint in IMAGE_GEN_PULL_MODELS (menu + specs below).
#   3. Bring the stack up with the `imagegen` profile (also downloads the model):
#        docker compose -f compose.selfhost.yaml --env-file .env.selfhost --profile imagegen up -d
#      (add `-f compose.imagegen-gpu.yaml` before --env-file for NVIDIA GPU.)
#
# Prefer an SD server you already run on the host? Point at it instead (no
# `imagegen` profile needed): IMAGE_GEN_BASE_URL=http://host.docker.internal:7860
#
# IMAGE_GEN_BASE_URL=http://imagegen:7860

# Checkpoint(s) the bundled puller downloads (space-separated .safetensors URLs
# from a public host). They land in the SD models dir and appear in the picker.
# "GPU VRAM" = fits comfortably on that GPU; with less it still runs, spilling to
# CPU RAM (slower). "CPU-only RAM" = usable with no GPU (~1-3 min/image).
#
#   Checkpoint            Download   Min GPU VRAM   CPU-only RAM   License
#   --------------------  --------   ------------   ------------   ---------------------------
#   SD 1.5 (default)      ~4.0 GB    ~4 GB          ~8 GB          CreativeML OpenRAIL-M
#   SDXL base 1.0         ~6.9 GB    ~10-12 GB      ~16 GB         CreativeML Open RAIL++-M
#
# SD 1.5:  https://huggingface.co/stable-diffusion-v1-5/stable-diffusion-v1-5/resolve/main/v1-5-pruned-emaonly.safetensors
# SDXL:    https://huggingface.co/stabilityai/stable-diffusion-xl-base-1.0/resolve/main/sd_xl_base_1.0.safetensors
# No GPU? Start with SD 1.5. Any A1111-compatible .safetensors URL works here.
IMAGE_GEN_PULL_MODELS=https://huggingface.co/stable-diffusion-v1-5/stable-diffusion-v1-5/resolve/main/v1-5-pruned-emaonly.safetensors

# Host port for the bundled imagegen server (loopback only). Override if 7860 is
# taken (e.g. by a host SD server).
# IMAGEGEN_HOST_PORT=7860

# Override the imagegen container image (default: SD.Next nVidia build, which
# also runs CPU-only). Any image serving the A1111 REST API on port 7860 works.
# IMAGEGEN_IMAGE=vladmandic/sdnext-cuda:latest

# -- Python artifacts offline (optional Pyodide mirror) ------------------------
# Python artifacts run in the browser via Pyodide (WebAssembly). By default the runtime
# is fetched from the public jsDelivr CDN, so running a Python artifact needs internet.
# For an air-gapped / offline deployment, host the Pyodide v0.25.1 "full" distribution on
# your own server and point PYODIDE_BASE_URL at it (a trailing slash is added for you if omitted).
#
# What to mirror (from the pyodide v0.25.1 full dist): pyodide.js, the asm wasm/js files,
# the Python stdlib zip, repodata.json, and any package wheels your artifacts import.
# A cross-origin mirror must send permissive CORS headers (the worker fetches these assets),
# and its origin is added to the app CSP (script-src + connect-src) automatically. Leave
# unset to use the default CDN.
# PYODIDE_BASE_URL=http://localhost:8080/pyodide/v0.25.1/full/

