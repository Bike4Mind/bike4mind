# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/playwright-report/
/test-results/
e2e/.auth/
e2e/test-results/
e2e/fixtures/credits.json
.env.e2e

# next.js
/.next/
/.open-next
/out/

# sst
/.sst/
.sst.config.*.mjs

# production
/build

# misc
.DS_Store
*.pem

/server/dist

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#amplify-do-not-edit-begin
amplify/\#current-cloud-backend
amplify/.config/local-*
amplify/logs
amplify/mock-data
amplify/mock-api-resources
amplify/backend/amplify-meta.json
amplify/backend/.temp
build/
dist/
node_modules/
aws-exports.js
awsconfiguration.json
amplifyconfiguration.json
amplifyconfiguration.dart
amplify-build-config.json
amplify-gradle-config.json
amplifytools.xcconfig
.secret-*
**.sample
#amplify-do-not-edit-end

/data

.env
.env.local

# pdfjs express viewer
public/ui
public/core
public/pdfjs
public/pdfjs-express-viewer

# pdf.js worker (copied from pdfjs-dist by scripts/copy-pdf-worker.mjs)
public/pdf.worker.min.mjs

# Serwist
public/sw*
public/swe-worker*

# Help content (generated by `pnpm --filter @bike4mind/scripts help:bundle-content`)
public/help-content/*
!public/help-content/**/.gitkeep

# Premium overlay codegen (M1a, Open Core). Generated by scripts/generate-premium-glue.mjs.
# gitignored ≠ tsc-ignored — these files stay in tsconfig include globs so type errors surface.
app/premium-generated/
pages/api/premium-*/
server/premium-generated/

# Tavern public assets — copied from packages/premium/tavern/public by postinstall.
public/assets/tavern/
