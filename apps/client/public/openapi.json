      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "request_id": {
            "type": "string",
            "description": "Correlation id, mirrors the X-Request-ID header."
          }
        },
        "required": [
          "error"
        ],
        "example": {
          "error": "Missing or invalid toolName",
          "request_id": "abc-123"
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/ai/v1/completions": {
      "post": {
        "operationId": "createCompletion",
        "summary": "Create a chat completion",
        "description": "OpenAI-compatible completion. The response is ALWAYS an SSE stream (`text/event-stream`), regardless of the `stream` flag: a `meta` event, then `content`/`tool_use` events carrying `usage`/`credits`, terminated by `data: [DONE]`. Once the stream has opened the HTTP status stays 200 and failures arrive as an in-band `error` event. Authenticate with an API key (`b4m_live_`) or a JWT.",
        "tags": [
          "AI"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompletionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream of completion events (see CompletionStreamEvent).",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/CompletionStreamEvent"
                }
              }
            },
            "headers": {
              "X-Request-ID": {
                "description": "Correlation id for this request; safe to log and quote in support requests.",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Malformed JSON body (rejected before the stream opens).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {
              "X-Request-ID": {
                "description": "Correlation id for this request; safe to log and quote in support requests.",
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "x-required-scopes": [
          "ai:chat",
          "ai:generate"
        ],
        "x-codeSamples": [
          {
            "lang": "curl",
            "label": "curl",
            "source": "curl -sN -X POST \"https://your-deployment.example.com/api/ai/v1/completions\" \\\n  -H \"Authorization: Bearer b4m_live_<key>\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"model\":\"claude-opus-4-8\",\"messages\":[{\"role\":\"user\",\"content\":\"How do I reset my password?\"}],\"max_tokens\":500}'"
          },
          {
            "lang": "JavaScript",
            "label": "fetch",
            "source": "const res = await fetch(\"https://your-deployment.example.com/api/ai/v1/completions\", {\n  method: \"POST\",\n  headers: {\n    \"Authorization\": \"Bearer b4m_live_<key>\",\n    \"Content-Type\": \"application/json\",\n  },\n  body: JSON.stringify({\n  \"model\": \"claude-opus-4-8\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"How do I reset my password?\"\n    }\n  ],\n  \"max_tokens\": 500\n}),\n});"
          },
          {
            "lang": "Python",
            "label": "requests",
            "source": "import requests\n\nres = requests.post(\n    \"https://your-deployment.example.com/api/ai/v1/completions\",\n    headers={\"Authorization\": \"Bearer b4m_live_<key>\"},\n    json={\n  \"model\": \"claude-opus-4-8\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"How do I reset my password?\"\n    }\n  ],\n  \"max_tokens\": 500\n},\n    stream=True,\n)"
          }
        ]
      }
    },
    "/api/ai/v1/tools": {
      "post": {
        "operationId": "executeTool",
        "summary": "Execute a server-side tool",
        "description": "Runs one of the built-in server-side tools (`weather_info`, `web_search`, `web_fetch`) and returns its result as JSON. Rate-limited to 100 requests/hour. `request_id` echoes the X-Request-ID response header.",
        "tags": [
          "AI"
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToolExecutionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tool executed successfully (`success` is always true here).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolExecutionResponse"
                }
              }
            },
            "headers": {
              "X-Request-ID": {
                "description": "Correlation id for this request; safe to log and quote in support requests.",
                "schema": {
                  "type": "string"
                }
              },
              "X-RateLimit-Limit": {
                "description": "Request quota for the window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Remaining": {
                "description": "Requests remaining in the window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Reset": {
                "description": "Unix epoch (seconds) when the window resets.",
                "schema": {
                  "type": "integer"
                }
              }
            }
          },
          "400": {
            "description": "Missing/invalid `toolName` or `input`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {
              "X-Request-ID": {
                "description": "Correlation id for this request; safe to log and quote in support requests.",
                "schema": {
                  "type": "string"
                }
              },
              "X-RateLimit-Limit": {
                "description": "Request quota for the window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Remaining": {
                "description": "Requests remaining in the window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Reset": {
                "description": "Unix epoch (seconds) when the window resets.",
                "schema": {
                  "type": "integer"
                }
              }
            }
          },
          "500": {
            "description": "Tool execution failed; body carries `success: false` with `error`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolExecutionResponse"
                }
              }
            },
            "headers": {
              "X-Request-ID": {
                "description": "Correlation id for this request; safe to log and quote in support requests.",
                "schema": {
                  "type": "string"
                }
              },
              "X-RateLimit-Limit": {
                "description": "Request quota for the window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Remaining": {
                "description": "Requests remaining in the window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Reset": {
                "description": "Unix epoch (seconds) when the window resets.",
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "x-required-scopes": [
          "ai:chat",
          "ai:generate"
        ],
        "x-codeSamples": [
