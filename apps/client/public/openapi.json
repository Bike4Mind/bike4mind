      },
      "ToolExecutionRequest": {
        "type": "object",
        "properties": {
          "toolName": {
            "type": "string",
            "enum": [
              "weather_info",
              "web_search",
              "web_fetch"
            ]
          },
          "input": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "required": [
          "toolName",
          "input"
        ],
        "description": "Server-side tool execution request. Not the same shape as a completion `tools` entry.",
        "example": {
          "toolName": "web_search",
          "input": {
            "query": "how to reset a password"
          }
        }
      },
      "ToolExecutionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "result": {},
          "error": {
