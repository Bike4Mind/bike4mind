{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.d.ts"],
  "references": [
    { "path": "../common" },
    { "path": "../utils" },
    { "path": "../services" },
    { "path": "../mcp" }
  ]
}
