{
  "name": "bike4mind",
  "version": "0.7.25.02.34",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -fr node_modules packages/{common,server}/node_modules apps/client/node_modules {,apps/client/}{.next,.open-next} tsconfig.tsbuildinfo .sst/dist b4m-core/node_modules b4m-core/*/dist b4m-core/*/node_modules b4m-core/mcp/servers/*/node_modules .turbo b4m-core/*/.turbo apps/*/.turbo packages/*/.turbo",
    "bootstrap:premium": "bash scripts/bootstrap-premium.sh",
    "premium:pin": "node scripts/premium-pin.mjs",
    "daily-insights:generate": "pnpm --filter scripts daily-insights:generate",
    "db:create-user": "pnpm --filter scripts db:create-user",
    "db:seed-users": "pnpm --filter client db:seed-users",
    "dev": "pnpm --filter client dev",
    "boot": "./for-env local ./dev",
    "edev": "./for-env local ./dev",
    "start": "./for-env local ./dev",
    "up": "./for-env local ./dev",
    "tavern:upload-icons": "pnpm --filter @bike4mind/scripts tavern:upload-icons",
    "dev-fast": "MONGODB_MAX_POOL_SIZE=10 NODE_ENV=development ./dev-fast",
    "docs:build": "cd docs-site && pnpm build",
    "docs:dev": "cd docs-site && pnpm start",
    "build": "pnpm core:build",
    "core:build": "pnpm --filter \"./b4m-core/*\" --filter \"./packages/database\" --filter \"./packages/premium/*/engine\" --filter \"./packages/premium/*/engine-container\" build",
    "core:incremental": "pnpm --filter \"./b4m-core/*\" --filter \"./packages/database\" incremental",
    "core:dev": "pnpm --filter \"./b4m-core/*\" --filter \"./packages/database\" --parallel dev",
    "core:clean": "pnpm --filter \"./b4m-core/*\" --filter \"./packages/database\" clean",
    "turbo:build": "turbo build --filter='!@bike4mind/client'",
    "turbo:core:build": "turbo build --filter='./b4m-core/*' --filter='./packages/database' --filter='./packages/premium/*/engine' --filter='./packages/premium/*/engine-container'",
    "turbo:typecheck": "turbo typecheck",
    "turbo:typecheck:native": "turbo typecheck:native",
    "turbo:typecheck:fast": "turbo typecheck:fast",
    "turbo:test": "turbo test",
    "turbo:openapi:generate": "turbo openapi:generate --filter @bike4mind/common",
    "import-polaris-data": "pnpm --filter scripts import-polaris-data",
    "lint": "eslint .",
    "lint:check": "eslint . --quiet --cache --cache-location node_modules/.cache/eslint/",
    "lint:md": "markdownlint '**/*.md' '**/*.mdx' --ignore node_modules",
    "lint:md:fix": "markdownlint '**/*.md' '**/*.mdx' --ignore node_modules --fix",
    "migrate": "pnpm --filter scripts migrate",
    "pre-push": "pnpm exec turbo typecheck:fast && pnpm run typecheck:infra:local",
    "prepare": "husky || true",
    "sst": "sst",
    "sst:unlock:force": "bash scripts/sst-force-unlock.sh",
    "dev:reset": "bash scripts/dev-reset.sh",
    "test": "pnpm -r test",
    "test:e2e:setup": "pnpm --filter client test:e2e:setup",
    "test:e2e": "pnpm --filter client test:e2e",
    "test:e2e:ui": "pnpm --filter client test:e2e:ui",
    "test:e2e:headed": "pnpm --filter client test:e2e:headed",
    "test:e2e:report": "pnpm --filter client test:e2e:report",
    "test:email-ingestion": "pnpm --filter scripts test:email-ingestion",
    "typecheck": "tsc --noEmit",
    "typecheck:infra": "tsc -p infra/tsconfig.json --noEmit",
    "typecheck:infra:local": "if [ -f .sst/platform/config.d.ts ]; then pnpm run typecheck:infra; else echo '⏭️  Skipping infra typecheck — run sst install to enable it locally (CI still gates it)'; fi",
    "typecheck:native": "tsgo --noEmit --types node",
    "typecheck:fast": "tsgo --noEmit --types node || tsc --noEmit",
    "weekly-insights:generate": "pnpm --filter scripts weekly-insights:generate",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status"
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "^3.1080.0",
    "@aws-sdk/client-ssm": "^3.1080.0",
    "@bike4mind/infra": "workspace:*",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tsconfig/node24": "^24.0.0",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint": "^0.41.1",
    "markdownlint-cli": "^0.49.1",
    "mongodb": "^6.20.0",
    "prettier": "^3.9.5",
    "ts-morph": "^28.0.0",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "sst": "4.14.1"
  },
  "overrides": {
    "canvas": "../_EXCLUDED_"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "b4m-core/*"
  ],
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "esbuild-wasm": "0.28.1",
      "@smithy/core": "3.29.0",
      "@smithy/types": "4.15.1",
      "axios": "1.18.0",
      "minimatch@<3.1.3": "3.1.5",
      "tar@<7.5.8": "^7.5.8",
      "mathjs@<7.5.1": "^7.5.1",
      "@xmldom/xmldom": "^0.8.13",
      "@grpc/grpc-js": "^1.14.4",
      "qs@<6.15.2": "^6.15.2",
      "postcss@<8.5.10": "^8.5.10",
      "@babel/core@<7.29.6": "^7.29.6",
      "ip-address@<10.1.1": "^10.1.1",
      "uuid@<11.1.1": "^11.1.1",
      "shell-quote@<1.9.0": "^1.9.0",
      "brace-expansion@>=2.0.0 <2.1.2": "^2.1.2",
      "brace-expansion@<1.1.16": "^1.1.16",
      "protobufjs@>=7.5.0 <7.6.5": "^7.6.5",
      "body-parser@>=2.0.0 <2.3.0": "^2.3.0",
      "body-parser@<1.20.6": "^1.20.6",
      "fast-uri@>=3.0.0 <3.1.4": "^3.1.4",
      "sharp@<0.35.0": "^0.35.3",
      "@hono/node-server@<2.0.5": "^2.0.5"
    },
    "ignoredBuiltDependencies": [
      "aws-sdk",
      "canvas",
      "core-js",
      "mongodb-memory-server",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@swc/core",
      "@vscode/ripgrep",
      "better-sqlite3",
      "esbuild",
      "isolated-vm",
      "protobufjs",
      "sharp"
    ]
  }
}
