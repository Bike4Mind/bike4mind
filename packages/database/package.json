{
  "name": "@bike4mind/database",
  "version": "0.1.57",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./auth": {
      "types": "./dist/models/auth/index.d.mts",
      "default": "./dist/models/auth/index.mjs"
    },
    "./content": {
      "types": "./dist/models/content/index.d.mts",
      "default": "./dist/models/content/index.mjs"
    },
    "./social": {
      "types": "./dist/models/social/index.d.mts",
      "default": "./dist/models/social/index.mjs"
    },
    "./billing": {
      "types": "./dist/models/billing/index.d.mts",
      "default": "./dist/models/billing/index.mjs"
    },
    "./ai": {
      "types": "./dist/models/ai/index.d.mts",
      "default": "./dist/models/ai/index.mjs"
    },
    "./infra": {
      "types": "./dist/models/infra/index.d.mts",
      "default": "./dist/models/infra/index.mjs"
    },
    "./hearth": {
      "types": "./dist/models/hearth/index.d.mts",
      "default": "./dist/models/hearth/index.mjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsdown",
    "incremental": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit --types node",
    "typecheck:fast": "tsgo --noEmit --types node || tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "generate:model-price-seed": "tsx src/seeds/regenerateModelPriceSeed.ts"
  },
  "dependencies": {
    "@bike4mind/common": "workspace:*",
    "@bike4mind/db-core": "workspace:*",
    "@bike4mind/hearth": "workspace:*",
    "@bike4mind/llm-adapters": "workspace:*",
    "@bike4mind/utils": "workspace:*",
    "@casl/ability": "^6.8.1",
    "@casl/mongoose": "^8.0.5",
    "bcryptjs": "^3.0.2",
    "dayjs": "^1.11.21",
    "mongoose": "^8.24.1",
    "mongoose-lean-virtuals": "^2.1.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "mongodb-memory-server": "^11.2.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
