{
  "name": "@bike4mind/scripts",
  "version": "0.1.61",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./migrate/migrationManager": "./migrate/migrationManager.ts",
    "./help/types": "./help/types.ts",
    "./help/utils": "./help/utils.ts",
    "./help/loadHelpArticles": "./help/loadHelpArticles.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit --types node",
    "typecheck:fast": "tsgo --noEmit --types node || tsc --noEmit",
    "migrate": "tsx migrate/index.ts",
    "datalake:check-slug-dupes": "tsx migrate/check-datalake-slug-dupes.ts",
    "db:create-user": "tsx createUser.ts",
    "db:list-users": "tsx listUsers.ts",
    "db:setup-email-user": "tsx setupTestEmailUser.ts",
    "daily-insights:generate": "tsx generateUserActivity.ts",
    "weekly-insights:generate": "tsx generateWeeklyUserActivity.ts",
    "translations:sync": "tsx syncTranslations.ts",
    "clear-resume-tokens": "tsx src/clear-resume-tokens.ts",
    "db:cleanup": "tsx migrate/index.ts cleanup",
    "cleanup:query-subscriptions": "tsx cleanupOldQuerySubscriptions.ts",
    "test:email-ingestion": "tsx testEmailIngestLambda.ts",
    "test:api-usage": "tsx test-api-usage-monitoring.ts",
    "test:agent-execute-ws": "tsx testAgentExecuteWs.ts",
    "create-prod-release": "tsx src/createProductionRelease.ts",
    "help:ingest-datalake": "tsx help/ingest-help-datalake.ts",
    "help:build-index": "tsx help/build-help-index.ts",
    "help:validate": "tsx help/validate-help-content.ts",
    "help:coverage": "tsx help/help-coverage-report.ts",
    "help:bundle-content": "tsx help/bundle-help-content.ts",
    "help:vectorize": "tsx help/vectorize-help-content.ts",
    "help:regenerate": "pnpm help:build-index && pnpm help:bundle-content && pnpm help:vectorize",
    "test:seed-context-summary": "tsx seedContextSummary.ts",
    "migrate:encrypt-tokens": "tsx migrate/encrypt-tokens-at-rest.ts",
    "backfill:pending-free-credits": "tsx backfillPendingFreeCredits.ts",
    "backfill:fabfile-moderation-status": "tsx src/backfill-fabfile-moderation-status.ts",
    "tavern:upload-icons": "tsx src/uploadTavernIcons.ts"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1069.0",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/client-sqs": "^3.1069.0",
    "@aws-sdk/client-ssm": "^3.1069.0",
    "@bike4mind/common": "workspace:*",
    "@bike4mind/database": "workspace:*",
    "@bike4mind/fab-pipeline": "workspace:*",
    "@bike4mind/llm-adapters": "workspace:*",
    "@bike4mind/observability": "workspace:*",
    "@bike4mind/services": "workspace:*",
    "@bike4mind/utils": "workspace:*",
    "@faker-js/faker": "^10.4.0",
    "@inquirer/prompts": "^8.4.3",
    "axios": "1.16.1",
    "bcryptjs": "^3.0.2",
    "csv-parser": "^3.2.1",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "glob": "^13.0.0",
    "gray-matter": "^4.0.3",
    "mongoose": "^8.24.1",
    "p-limit": "^7.3.0",
    "sst": "4.14.1",
    "typescript": "^5.9.3",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/yargs": "^17.0.35",
    "mailparser": "^3.9.12",
    "ora": "^9.4.0",
    "tsx": "^4.22.3",
    "vitest": "^4.1.9"
  }
}
